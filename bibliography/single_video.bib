% url = {https://arxiv.org/abs/1906.09909},
@inproceedings{2019-deep-exemplar-based-video-colorization,
  author    = {Zhang, Bo and He, Mingming and Liao, Jing and Sander, Pedro V. and Yuan, Lu and Bermak, Amine and Chen, Dong},
  title     = {Deep Exemplar-Based Video Colorization},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  month     = jun,
  year      = {2019},
  volume    = {},
  number    = {},
  pages     = {8044-8053},
  publisher = {IEEE},
  address   = {Long Beach, CA, USA},
  isbn      = {9781728132938},
  doi       = {10.1109/CVPR.2019.00824},
  url       = {https://openaccess.thecvf.com/content_CVPR_2019/html/Zhang_Deep_Exemplar-Based_Video_Colorization_CVPR_2019_paper.html},
  abstract  = {This paper presents the first end-to-end network for exemplar-based video colorization. The main challenge is to achieve temporal consistency while remaining faithful to the reference style. To address this issue, we introduce a recurrent framework that unifies the semantic correspondence and color propagation steps. Both steps allow a provided reference image to guide the colorization of every frame, thus reducing accumulated propagation errors. Video frames are colorized in sequence based on the colorization history, and its coherency is further enforced by the temporal consistency loss. All of these components, learned end-to-end, help produce realistic videos with good temporal stability. Experiments show our result is superior to the state-of-the-art methods both quantitatively and qualitatively.},
  keywords  = {Training;Computer vision;Image color analysis;Semantics;Pattern recognition;History;Videos;Computational Photography;Deep Learning},
  language  = {english},
  langid    = {english}
}

% url = {https://arxiv.org/abs/2208.09392},
@inproceedings{2019-fully-automatic-video-colorization,
  author    = {Lei, Chenyang and Chen, Qifeng},
  title     = {Fully Automatic Video Colorization With Self-Regularization and Diversity},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  month     = jun,
  year      = {2019},
  volume    = {},
  number    = {},
  pages     = {8044-8053},
  publisher = {IEEE},
  address   = {Long Beach, CA, USA},
  isbn      = {9781728132938},
  issn      = {2575-7075},
  doi       = {10.1109/CVPR.2019.00388},
  url       = {https://openaccess.thecvf.com/content_CVPR_2019/html/Lei_Fully_Automatic_Video_Colorization_with_Self-Regularization_and_Diversity_CVPR_2019_paper.html},
  abstract  = {We present a fully automatic approach to video colorization with self-regularization and diversity. Our model contains a colorization network for video frame colorization and a refinement network for spatiotemporal color refinement. Without any labeled data, both networks can be trained with self-regularized losses defined in bilateral and temporal space. The bilateral loss enforces color consistency between neighboring pixels in a bilateral space and the temporal loss imposes constraints between corresponding pixels in two nearby frames. While video colorization is a multi-modal problem, our method uses a perceptual loss with diversity to differentiate various modes in the solution space. Perceptual experiments demonstrate that our approach outperforms state-of-the-art approaches on fully automatic video colorization.},
  keywords  = {Computer vision;Image color analysis;Spatiotemporal phenomena;Pattern recognition;Videos;Vision + Graphics;Computational Photography; Image and Video Synthesis; Low-level Vision},
  language  = {english},
  langid    = {english}
}

