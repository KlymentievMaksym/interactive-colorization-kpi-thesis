              \parbox[c]{.68\paperwidth}{\centering \reportTitle}%
          \end{beamercolorbox}%
          \begin{beamercolorbox}[wd=.06\paperwidth, ht=4ex, dp=3.5ex, center]{palette secondary}%
              \Year%
          \end{beamercolorbox}%
